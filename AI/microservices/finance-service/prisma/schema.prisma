generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserCurrency {
  VND

  @@map("enum_users_currency")
}

enum UserRole {
  USER @map("user")

  @@map("enum_users_role")
}

enum CategoryType {
  EXPENSE @map("expense")
  INCOME  @map("income")

  @@map("enum_categories_type")
}

enum TransactionType {
  EXPENSE @map("expense")
  INCOME  @map("income")

  @@map("enum_transactions_type")
}

model User {
  id           Int           @id @default(autoincrement())
  name         String?
  currency     UserCurrency? @default(VND)
  avatarId     Int?          @map("avatar_id")
  updatedAt    DateTime      @default(now()) @map("updated_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  email        String
  role         UserRole      @default(USER)
  categories   Category[]
  wallets      Wallet[]
  transactions Transaction[]

  @@map("users")
}

model Category {
  id           Int           @id @default(autoincrement())
  name         String
  type         CategoryType
  icon         String?
  color        String?
  userId       Int?          @map("user_id")
  isDefault    Boolean?      @default(false) @map("is_default")
  updatedAt    DateTime      @default(now()) @map("updated_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  transactions Transaction[]

  @@map("categories")
}

model Wallet {
  id           Int           @id @default(autoincrement())
  userId       Int           @map("user_id")
  name         String
  walletType   String        @default("cash") @map("wallet_type")
  currency     String        @default("VND")
  balance      Decimal       @default(0)
  isDefault    Boolean       @default(false) @map("is_default")
  updatedAt    DateTime      @default(now()) @map("updated_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("wallets")
}

model Transaction {
  id           Int       @id @default(autoincrement())
  type         TransactionType
  amount       Decimal
  categoryId   Int       @map("category_id")
  description  String?
  date         DateTime  @map("date")
  note         String?
  receiptId    Int?      @map("receipt_id")
  userId       Int       @map("user_id")
  updatedAt    DateTime  @default(now()) @map("updated_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  walletId     Int?      @map("wallet_id")
  merchantName String?   @map("merchant_name")
  sourceType   String?   @map("source_type")
  sourceRefId  String?   @map("source_ref_id")
  category     Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet       Wallet?   @relation(fields: [walletId], references: [id], onDelete: SetNull)

  @@map("transactions")
}
