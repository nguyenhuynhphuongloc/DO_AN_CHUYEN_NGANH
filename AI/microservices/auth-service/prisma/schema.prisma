generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserCurrency {
  VND

  @@map("enum_users_currency")
}

enum UserRole {
  USER @map("user")

  @@map("enum_users_role")
}

model User {
  id                      Int            @id @default(autoincrement())
  name                    String?
  currency                UserCurrency?  @default(VND)
  avatarId                Int?           @map("avatar_id")
  updatedAt               DateTime       @default(now()) @map("updated_at")
  createdAt               DateTime       @default(now()) @map("created_at")
  email                   String         @unique(map: "users_email_idx")
  resetPasswordToken      String?        @map("reset_password_token")
  resetPasswordExpiration DateTime?      @map("reset_password_expiration")
  salt                    String?
  hash                    String?
  loginAttempts           Decimal?       @map("login_attempts")
  lockUntil               DateTime?      @map("lock_until")
  role                    UserRole       @default(USER)
  refreshTokens           RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String    @id
  userId    Int       @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "refresh_tokens_user_id_idx")
  @@map("refresh_tokens")
}
