HOST=127.0.0.1
PORT=5002
AUTH_DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require
AUTH_AUTO_MIGRATE=false
AUTH_JWT_SECRET=change-me-access-secret
AUTH_REFRESH_TOKEN_SECRET=change-me-refresh-secret
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=30d
CORS_ORIGIN=http://localhost:5000
