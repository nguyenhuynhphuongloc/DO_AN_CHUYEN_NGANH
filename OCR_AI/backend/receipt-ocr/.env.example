# n8n runtime
N8N_PORT=5001
N8N_HOST=0.0.0.0
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=replace-with-a-long-random-string
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin123
WEBHOOK_URL=http://localhost:5001/

# Veryfi credentials
VERYFI_CLIENT_ID=replace-me
VERYFI_USERNAME=replace-me
VERYFI_API_KEY=replace-me

# OCR validation
OCR_REQUIRED_CONFIDENCE=0.65
OCR_DEFAULT_CURRENCY=VND
